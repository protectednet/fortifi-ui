{
  "name": "fortifi/ui",
  "description": "Fortifi UI",
  "homepage": "http://fortifi.co/ui",
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Brooke Bryan",
      "email": "brooke@bajb.net"
    }
  ],
  "minimum-stability": "dev",
  "require": {
    "php": ">=7.2",
    "packaged/dispatch": "^2.0",
    "packaged/glimpse": "^2.0",
    "nesbot/carbon": "^2.73.0 || ^3.8.4",
    "illuminate/contracts": "^v8.0 || ^v9.0 || ^v10.0 || ^v11.0 || ^v12.0 || ^v13.0",
    "fortifi/fontawesome": "^3.0"
  },
  "require-dev": {
    "cubex/framework": "*",
    "packaged/docblock": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Fortifi\\Ui\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Fortifi\\UiExample\\": "example_src/"
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "git@github.com:fortifi/fontawesome.git"
    }
  ]
}
